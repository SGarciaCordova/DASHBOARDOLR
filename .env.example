# ==========================================
# ANTIGRAVITY SGC - CONFIGURACIÓN DE ENTORNO
# ==========================================

# --- Autenticación y Seguridad ---
# Para SQLite local (por defecto):
DATABASE_URL=sqlite:///./auth_system/auth.db
# Configuración de zona horaria
TZ=America/Mexico_City

# Configuración de base de datos
# Cambiar por esta si se usa servidor de base de datos externo:
# DATABASE_URL=mysql+pymysql://user:password@host:port/database_name

# Generar una clave larga y segura para persistencia de sesiones
JWT_SECRET_KEY=cambiar_por_una_clave_aleatoria_larga

# Admin Inicial (para script create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password_seguro

# --- Configuración de Scraper WMS Reebok ---
WMS_URL=https://apolo.soft-gator.com/gatorwolr/index.jsp
WMS_USER=tu_usuario_wms
WMS_PASS=tu_password_wms

# --- Configuración Docker ---
# 1 = Ejecución en Docker (activa modo headless para Selenium)
# 0/vacío = Ejecución local normal
DOCKER_ENV=1

